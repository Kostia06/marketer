      },
      "id": "review-webhook",
      "name": "Review Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300]
    },
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst DRAFTS_PATH = '/home/node/.n8n/marketer/drafts.json';\nconst query = $input.first().json.query;\nconst action = query.action;\nconst draftId = query.id;\nif (!action || !draftId) {\n  return [{ json: { error: true, message: 'Missing action or id parameter' } }];\n}\nconst drafts = JSON.parse(fs.readFileSync(DRAFTS_PATH, 'utf8'));\nconst draft = drafts.drafts.find(d => d.id === draftId);\nif (!draft) {\n  return [{ json: { error: true, message: `Draft ${draftId} not found` } }];\n}\nif (draft.status !== 'pending') {\n  return [{ json: { error: false, action: 'already_handled', draft, message: `Draft already ${draft.status}` } }];\n}\nreturn [{ json: { error: false, action, draft, draftId, draftsPath: DRAFTS_PATH } }];"
      },
      "id": "load-draft",
      "name": "Load Draft",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "approve",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "approve"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.action }}",
                    "rightValue": "reject",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "reject"
            },
            {
              "conditions": {
                "options": {
                  "caseSensitive": true,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.error }}",
                    "rightValue": true,
                    "operator": {
                      "type": "boolean",
                      "operation": "true"
                    }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "error"
            }
          ]
        },
        "options": {
          "fallbackOutput": "extra"
        }
      },
      "id": "route-action",
      "name": "Route Action",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3,
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst { draftId, draftsPath } = $input.first().json;\nconst drafts = JSON.parse(fs.readFileSync(draftsPath, 'utf8'));\nconst draft = drafts.drafts.find(d => d.id === draftId);\ndraft.status = 'approved';\nfs.writeFileSync(draftsPath, JSON.stringify(drafts, null, 2));\nreturn [{ json: { draftId, status: 'approved', topic: draft.topic, contentType: draft.contentType } }];"
      },
      "id": "approve-draft",
      "name": "Approve Draft",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 160]
    },
    {
      "parameters": {
        "jsCode": "const fs = require('fs');\nconst { draftId, draftsPath } = $input.first().json;\nconst drafts = JSON.parse(fs.readFileSync(draftsPath, 'utf8'));\nconst draft = drafts.drafts.find(d => d.id === draftId);\ndraft.status = 'rejected';\nfs.writeFileSync(draftsPath, JSON.stringify(drafts, null, 2));\nreturn [{ json: { draftId, status: 'rejected', topic: draft.topic, contentType: draft.contentType } }];"
      },
      "id": "reject-draft",
      "name": "Reject Draft",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [900, 300]
    },
