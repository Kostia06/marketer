    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "=<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>{{ $('Approve Draft').first()?.json?.status === 'approved' || $('Reject Draft').first()?.json?.status ? ($json.status === 'approved' ? 'Approved' : 'Rejected') : 'Done' }}</title>\n  <style>\n    body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: #f9fafb; }\n    .card { background: white; border-radius: 16px; padding: 40px 32px; text-align: center; box-shadow: 0 4px 24px rgba(0,0,0,0.08); max-width: 400px; width: 90%; }\n    .icon { font-size: 56px; margin-bottom: 16px; }\n    h1 { font-size: 24px; font-weight: 700; margin: 0 0 8px; color: #111827; }\n    .topic { font-size: 15px; color: #6b7280; margin: 0 0 24px; }\n    .close-hint { font-size: 13px; color: #9ca3af; }\n  </style>\n</head>\n<body>\n  <div class=\"card\">\n    <div class=\"icon\">{{ $json.status === 'approved' ? '✅' : '❌' }}</div>\n    <h1>Draft {{ $json.status === 'approved' ? 'Approved' : 'Rejected' }}</h1>\n    <p class=\"topic\">{{ $json.topic }}</p>\n    <p class=\"close-hint\">You can close this tab.</p>\n  </div>\n</body>\n</html>",
        "options": {
          "responseHeaders": {
            "values": [
              {
                "name": "Content-Type",
                "value": "text/html"
              }
            ]
          }
        }
      },
