      "parameters": {
        "method": "POST",
        "url": "={{ $env.MARKETER_DISCORD_WEBHOOK }}",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"embeds\": [\n    {\n      \"title\": \"{{ $json.status === 'approved' ? 'Draft Approved ✅' : 'Draft Rejected ❌' }}\",\n      \"color\": {{ $json.status === 'approved' ? 5763719 : 15548997 }},\n      \"description\": \"**Type:** {{ $json.contentType }}\\n**Topic:** {{ $json.topic }}\",\n      \"footer\": {\n        \"text\": \"Draft ID: {{ $json.draftId }}\"\n      }\n    }\n  ]\n}",
        "options": {}
      },
      "id": "discord-confirmation",
      "name": "Discord Confirmation",
